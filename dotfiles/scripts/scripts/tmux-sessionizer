#!/bin/bash

# EXKLUSIVE AUSWAHL:
# 1. Wir nehmen den Ordner 'solyshi-workstation' direkt (-maxdepth 0)
# 2. Wir nehmen alle Unterordner von '~/projects' (-maxdepth 1)
# Wir kombinieren beide Ergebnisse
selected=$(printf "%s\n" "$HOME/solyshi-workstation" $(find ~/projects -maxdepth 1 -mindepth 1 -type d) | fzf \
    --height 40% \
    --reverse \
    --border \
    --prompt="󱫋 Projekte > " \
    --preview 'ls -p --color=always {} | head -20')

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

# Session Logik (bleibt gleich)
if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s $selected_name -c "$selected"
    exit 0
fi

if ! tmux has-session -t=$selected_name 2> /dev/null; then
    tmux new-session -ds $selected_name -c "$selected"
fi

if [[ -z $TMUX ]]; then
    tmux attach-session -t $selected_name
else
    tmux switch-client -t $selected_name
fi
